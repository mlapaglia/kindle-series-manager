FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    sqlite3 \
    shellcheck \
    zip \
    unzip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
RUN python3 -m venv /venv && /venv/bin/pip install pytest

COPY . .

ENV PATH="/venv/bin:$PATH"
